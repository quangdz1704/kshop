# Local development uses SQLite by default.
DATABASE_URL="file:./dev.db"

# Production example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
# If your provider gives pooled and direct URLs, use pooled DATABASE_URL for the app
# and set DIRECT_URL for migration tooling if you wire that into CI.
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"

MOMO_PARTNER_CODE=""
MOMO_ACCESS_KEY=""
MOMO_SECRET_KEY=""
MOMO_ENVIRONMENT="sandbox"

# Public client-side value. Do not put secrets in NEXT_PUBLIC_* variables.
NEXT_PUBLIC_FB_PAGE_ID=""
